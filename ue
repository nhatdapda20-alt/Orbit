local function updateESP()
    for player, obj in pairs(espObjects) do
        local char = player.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then
            obj.boxOutline.Visible = false; continue
        end
        if not settings.espShowTeam and player.Team == LocalPlayer.Team then
            obj.boxOutline.Visible = false; continue
        end
        local root = char:FindFirstChild("HumanoidRootPart")
        local head = char:FindFirstChild("Head")
        local hum = char:FindFirstChild("Humanoid")
        if not root or not hum or hum.Health <= 0 then
            obj.boxOutline.Visible = false; continue
        end
        local headPos = head and head.Position or root.Position + Vector3.new(0, 2.5, 0)
        local footPos = root.Position - Vector3.new(0, 3, 0)
        local screenHead, onScreen = Camera:WorldToViewportPoint(headPos)
        local screenFoot = Camera:WorldToViewportPoint(footPos)
        if not onScreen then
            obj.boxOutline.Visible = false; continue
        end
        local height = math.abs(screenFoot.Y - screenHead.Y)
        local width = height * 0.65
        local x = screenHead.X - width / 2
        local y = screenHead.Y
        
        if settings.espBox then
            obj.boxOutline.Visible = true
            obj.boxOutline.Position = UDim2.new(0, x - 1, 0, y - 1)
            obj.boxOutline.Size = UDim2.new(0, width + 2, 0, height + 2)
            obj.boxInner.Size = UDim2.new(0, width + 2, 0, height + 2)
            obj.boxFill.Size = UDim2.new(0, width, 0, height)
            obj.boxFill.Visible = settings.espFill
        else
            obj.boxOutline.Visible = false
        end
        
        if settings.espName then
            obj.nameLabel.Visible = true
            obj.nameLabel.Text = player.Name
            obj.nameLabel.Position = UDim2.new(0, screenHead.X - 50, 0, y - 18)
            obj.nameLabel.Size = UDim2.new(0, 100, 0, 16)
        else
            obj.nameLabel.Visible = false
        end
        
        if settings.espDistance then
            local myChar = LocalPlayer.Character
            if myChar and myChar:FindFirstChild("HumanoidRootPart") then
                local dist = (myChar.HumanoidRootPart.Position - root.Position).Magnitude
                obj.distLabel.Visible = true
                obj.distLabel.Text = string.format("%.0f studs", dist)
                obj.distLabel.Position = UDim2.new(0, screenHead.X - 50, 0, screenFoot.Y + 2)
                obj.distLabel.Size = UDim2.new(0, 100, 0, 16)
            end
        else
            obj.distLabel.Visible = false
        end
        
        if settings.espWeapon then
            obj.weaponLabel.Visible = true
            local tool = char:FindFirstChildOfClass("Tool")
            obj.weaponLabel.Text = tool and tool.Name or "None"
            obj.weaponLabel.Position = UDim2.new(0, screenHead.X - 50, 0, screenFoot.Y + 16)
            obj.weaponLabel.Size = UDim2.new(0, 100, 0, 16)
        else
            obj.weaponLabel.Visible = false
        end
        
        if settings.espHealthbar then
            local healthPercent = hum.Health / hum.MaxHealth
            local barHeight = height * healthPercent
            local barX = x - 7
            obj.hpBg.Visible = true
            obj.hpBg.Position = UDim2.new(0, barX, 0, screenFoot.Y)
            obj.hpBg.Size = UDim2.new(0, 4, 0, height)
            obj.hpBar.Size = UDim2.new(0, 4, 0, barHeight)
            obj.hpBar.Position = UDim2.new(0, 0, 1, -barHeight)
            if healthPercent > 0.6 then obj.hpBar.BackgroundColor3 = Color3.new(0, 1, 0)
            elseif healthPercent > 0.3 then obj.hpBar.BackgroundColor3 = Color3.new(1, 0.8, 0)
            else obj.hpBar.BackgroundColor3 = Color3.new(1, 0, 0) end
        else
            obj.hpBg.Visible = false
        end
    end
end

