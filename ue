local function findNearestTarget()
    local nearest, minDist = nil, math.huge
    local myChar = LocalPlayer.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = myChar.HumanoidRootPart.Position
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local hum = p.Character:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 then
                local dist = (myPos - p.Character.HumanoidRootPart.Position).Magnitude
                if dist < minDist then minDist = dist; nearest = p end
            end
        end
    end
    return nearest
end

local function getHeadPosition(char)
    local head = char:FindFirstChild("Head")
    if head then return head.Position end
    local root = char:FindFirstChild("HumanoidRootPart")
    if root then return root.Position + Vector3.new(0, 5, 0) end
    return nil
end

local function getRagebotTarget()
    local target = findNearestTarget()
    if not target or not target.Character then return nil end
    if settings.ragebotPriority == "Head" then
        return target.Character:FindFirstChild("Head") or target.Character:FindFirstChild("HumanoidRootPart")
    elseif settings.ragebotPriority == "Body" then
        return target.Character:FindFirstChild("UpperTorso") or target.Character:FindFirstChild("HumanoidRootPart")
    else
        return target.Character:FindFirstChild("HumanoidRootPart")
    end
end

-- ============================================
-- VOID SPAM
-- ============================================
local function startVoidSpam()
    if voidConn then voidConn:Disconnect() end
    voidConn = RunService.Heartbeat:Connect(function()
        if not settings.voidActive then voidConn:Disconnect() return end
        local char = LocalPlayer.Character
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then return end
        root.CFrame = CFrame.new(root.Position.X, settings.voidDepth, root.Position.Z)
        root.Velocity = Vector3.zero
        local hum = char:FindFirstChild("Humanoid")
        if hum then
            hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
            hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
        end
    end)
end

local function stopVoidSpam()
    if voidConn then voidConn:Disconnect() voidConn = nil end
    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChild("Humanoid")
        if hum then
            hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
            hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, true)
        end
    end
end

-- ============================================
-- ORBIT
-- ============================================
local function startOrbit()
    local target = findNearestTarget()
    if not target then return end
    local angleBase, jitterPhase = 0, 0
    if orbitConn then orbitConn:Disconnect() end
    orbitConn = RunService.Heartbeat:Connect(function()
        if not settings.orbitActive then orbitConn:Disconnect() return end
        if not target or not target.Character or not target.Character:FindFirstChild("HumanoidRootPart") then
            target = findNearestTarget()
            if not target then settings.orbitActive = false; return end
        end
        local targetRoot = target.Character.HumanoidRootPart
        local myChar = LocalPlayer.Character
        if not myChar then return end
        local myRoot = myChar:FindFirstChild("HumanoidRootPart")
        if not myRoot then return end
        local now = tick()
        if now - lastTeleport < 1/math.max(settings.orbitSpeed, 1) then return end
        lastTeleport = now
        angleBase = (angleBase + 0.5) % (math.pi * 2)
        jitterPhase = jitterPhase + 0.7
        local r = settings.orbitRadius
        local tp = targetRoot.Position
        local bx = math.sin(angleBase) * r
        local bz = math.cos(angleBase) * r
        local jx = math.sin(jitterPhase * 5) * (r * 0.5) + math.random(-80, 80)
        local jy = math.cos(jitterPhase * 3) * (r * 0.6) + math.random(-80, 80) + 30
        local jz = math.sin(jitterPhase * 4) * (r * 0.4) + math.random(-80, 80)
        myRoot.CFrame = CFrame.new(tp.X + bx + jx, tp.Y + jy, tp.Z + bz + jz)
        myRoot.Velocity = Vector3.zero
    end)
end

local function stopOrbit()
    if orbitConn then orbitConn:Disconnect() orbitConn = nil end
end

-- ============================================
-- HEAD STOMP
-- ============================================
local function startHeadStomp()
    local target = findNearestTarget()
    if not target then return end
    local myChar = LocalPlayer.Character
    if myChar and myChar:FindFirstChild("HumanoidRootPart") then
        local headPos = getHeadPosition(target.Character)
        if headPos then
            myChar.HumanoidRootPart.CFrame = CFrame.new(headPos + Vector3.new(0, 3, 0))
        end
    end
    if headStompConn then headStompConn:Disconnect() end
    headStompConn = RunService.Heartbeat:Connect(function()
        if not settings.headStompActive then headStompConn:Disconnect() return end
        if not target or not target.Character or not target.Character:FindFirstChild("HumanoidRootPart") then
            target = findNearestTarget()
            if not target then settings.headStompActive = false; return end
        end
        local headPos = getHeadPosition(target.Character)
        local myChar = LocalPlayer.Character
        if headPos and myChar and myChar:FindFirstChild("HumanoidRootPart") then
            myChar.HumanoidRootPart.CFrame = CFrame.new(headPos + Vector3.new(0, 3, 0))
            myChar.HumanoidRootPart.Velocity = Vector3.zero
        end
    end)
end

local function stopHeadStomp()
    if headStompConn then headStompConn:Disconnect() headStompConn = nil end
end

-- ============================================
-- RAGEBOT
-- ============================================
local function startRagebot()
    if ragebotConn then ragebotConn:Disconnect() end
    local target = nil
    local voidState = "attack"
    ragebotConn = RunService.Heartbeat:Connect(function()
        if not settings.ragebotEnabled then ragebotConn:Disconnect() return end
        local newTarget = findNearestTarget()
        if not newTarget then return end
        target = newTarget
        if settings.ragebotVoidSpam then
            local char = LocalPlayer.Character
            if not char then return end
            local root = char:FindFirstChild("HumanoidRootPart")
            if not root then return end
            if voidState == "attack" then
                if target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                    local targetPos = target.Character.HumanoidRootPart.Position
                    root.CFrame = CFrame.new(targetPos + Vector3.new(math.random(-5, 5), 2, math.random(-5, 5)))
                end
                voidState = "hide"
                task.wait(settings.voidSpamDelay)
            else
                root.CFrame = CFrame.new(root.Position.X, settings.voidDepth, root.Position.Z)
                root.Velocity = Vector3.zero
                voidState = "attack"
                task.wait(settings.voidSpamDelay * 2)
            end
        end
        if target and target.Character then
            local targetPart = getRagebotTarget()
            if targetPart then
                pcall(function()
                    mouse1click()
                end)
            end
        end
    end)
end

local function stopRagebot()
    if ragebotConn then ragebotConn:Disconnect() ragebotConn = nil end
end

-- ============================================
-- AIMBOT
-- ============================================
local function getBestTarget()
    if not settings.aimbotEnabled then return nil end
    local best, bestDist = nil, settings.fovRadius
    local screenCenter = Camera.ViewportSize / 2
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LocalPlayer then continue end
        local char = p.Character
        if not char then continue end
        local head = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChild("Humanoid")
        if not head or not hum or hum.Health <= 0 then continue end
        if settings.visibleOnly then
            local rayParams = RaycastParams.new()
            rayParams.FilterDescendantsInstances = {LocalPlayer.Character, char}
            rayParams.FilterType = Enum.RaycastFilterType.Exclude
            local ray = workspace:Raycast(Camera.CFrame.Position, (head.Position - Camera.CFrame.Position).Unit * 1000, rayParams)
            if ray and ray.Instance and not ray.Instance:IsDescendantOf(char) then continue end
        end
        local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
        if not onScreen then continue end
        local dist = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
        if dist < bestDist then bestDist = dist; best = p end
    end
    return best
end

-- ============================================
-- BYPASS DETECTION (NO SPREAD + SILENT AIM + ANTI AIM)
-- ============================================
local mt = getrawmetatable(game)
local oldNamecall = mt.__namecall
setreadonly(mt, false)
mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    if method == "FireServer" then
        -- No Spread
        if settings.noSpread then
            pcall(function()
                for _, arg in pairs(args) do
                    if type(arg) == "table" then
                        if arg.Spread then arg.Spread = Vector3.zero end
                        if arg.SpreadAngle then arg.SpreadAngle = 0 end
                        if arg._ProjectileEffect then
                            arg._ProjectileEffect.Spread = Vector3.zero
                            arg._ProjectileEffect.SpreadAngle = 0
                        end
                    end
                end
            end)
        end
        -- Silent Aim
        if settings.silentAim and settings.aimbotEnabled then
            local target = getBestTarget()
            if target and target.Character and math.random(1, 100) <= settings.hitChance then
                local targetHead = target.Character:FindFirstChild("Head") or target.Character:FindFirstChild("HumanoidRootPart")
                if targetHead then
                    pcall(function()
                        for _, arg in pairs(args) do
                            if type(arg) == "table" then
                                if arg.Direction then
                                    arg.Direction = (targetHead.Position - Camera.CFrame.Position).Unit
                                end
                                if arg.Origin then
                                    arg.Origin = Camera.CFrame.Position
                                end
                            end
                        end
                    end)
                end
            end
        end
    end
    return oldNamecall(self, ...)
end)

