-- === TÌM MỤC TIÊU ===
local function findTarget()
    local nearest = nil
    local minDist = math.huge
    local myChar = player.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = myChar.HumanoidRootPart.Position
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local hum = p.Character:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 then
                local dist = (myPos - p.Character.HumanoidRootPart.Position).Magnitude
                if dist < minDist then
                    minDist = dist
                    nearest = p
                end
            end
        end
    end
    return nearest
end

-- === TÌM VỊ TRÍ ĐẦU ===
local function getHeadPosition(targetChar)
    local head = targetChar:FindFirstChild("Head")
    if head then return head.Position end
    
    local highestY = -math.huge
    local highestPos = nil
    
    for _, part in ipairs(targetChar:GetChildren()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
            local topY = part.Position.Y + (part.Size.Y / 2)
            if topY > highestY then
                highestY = topY
                highestPos = part.Position + Vector3.new(0, part.Size.Y / 2, 0)
            end
        end
    end
    
    if highestPos then return highestPos end
    
    local root = targetChar:FindFirstChild("HumanoidRootPart")
    if root then return root.Position + Vector3.new(0, 5, 0) end
    
    return nil
end

-- === ORBIT - SPAM LIÊN TỤC KHÔNG NGỪNG ===
local function startOrbit()
    if settings.active then return end
    if settings.headStomp then stopHeadStomp() end
    
    local target = findTarget()
    if not target then
        TargetLabel.Text = "🎯 TARGET: NO TARGET FOUND"
        return
    end
    
    settings.active = true
    settings.target = target
    
    StatusLabel.Text = "🟢 ORBIT ACTIVE"
    StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    TargetLabel.Text = "🎯 TARGET: " .. target.Name
    ToggleButton.Text = "STOP ORBIT"
    ToggleButton.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
    ToggleStroke.Color = Color3.fromRGB(255, 0, 0)
    workspace.Gravity = 0
    
    local angleBase = 0
    local jitterPhase = 0
    
    if orbitConn then orbitConn:Disconnect() end
    
    -- Dùng RenderStepped để spam mỗi FRAME (60 lần/giây)
    orbitConn = RunService.RenderStepped:Connect(function()
        if not settings.active then 
            orbitConn:Disconnect() 
            return 
        end
        
        -- Kiểm tra target
        if not settings.target or not settings.target.Character or not settings.target.Character:FindFirstChild("HumanoidRootPart") then
            settings.target = findTarget()
            if not settings.target then 
                stopOrbit() 
                return 
            end
            TargetLabel.Text = "🎯 TARGET: " .. settings.target.Name
        end
        
        local targetRoot = settings.target.Character.HumanoidRootPart
        local myChar = player.Character
        if not myChar then return end
        local myRoot = myChar:FindFirstChild("HumanoidRootPart")
        if not myRoot then return end
        
        -- SPAM LIÊN TỤC - KHÔNG CHECK INTERVAL
        angleBase = (angleBase + 1.2) % (math.pi * 2)
        jitterPhase = jitterPhase + 1.5
        
        local r = settings.radius
        local targetPos = targetRoot.Position
        
        -- Tạo vị trí quỹ đạo
        local baseX = math.sin(angleBase) * r
        local baseZ = math.cos(angleBase) * r
        local jitterX = math.sin(jitterPhase * 6) * (r * 0.7) + math.random(-settings.jitterAmount, settings.jitterAmount)
        local jitterY = math.cos(jitterPhase * 4) * (r * 0.8) + math.random(-settings.jitterAmount, settings.jitterAmount) + 40
        local jitterZ = math.sin(jitterPhase * 5) * (r * 0.6) + math.random(-settings.jitterAmount, settings.jitterAmount)
        
        local desiredPos = Vector3.new(
            targetPos.X + baseX + jitterX,
            targetPos.Y + jitterY,
            targetPos.Z + baseZ + jitterZ
        )
        
        -- TELEPORT MỖI FRAME
        myRoot.CFrame = CFrame.new(desiredPos) * CFrame.Angles(
            math.rad(math.random(-90, 90)),
            math.rad(math.random(0, 360)),
            math.rad(math.random(-90, 90))
        )
        myRoot.Velocity = Vector3.zero
        myRoot.RotVelocity = Vector3.zero
        
        -- Disable ragdoll
        local hum = myChar:FindFirstChild("Humanoid")
        if hum then
            hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
            hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
            hum:SetStateEnabled(Enum.HumanoidStateType.Climbing, false)
            hum:SetStateEnabled(Enum.HumanoidStateType.Seated, false)
            hum.PlatformStand = true
        end
    end)
end

local function stopOrbit()
    settings.active = false
    if orbitConn then orbitConn:Disconnect() orbitConn = nil end
    workspace.Gravity = 196.2
    local char = player.Character
    if char then
        local hum = char:FindFirstChild("Humanoid")
        if hum then
            hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
            hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, true)
            hum:SetStateEnabled(Enum.HumanoidStateType.Climbing, true)
            hum:SetStateEnabled(Enum.HumanoidStateType.Seated, true)
            hum.PlatformStand = false
        end
    end
    StatusLabel.Text = "🔴 INACTIVE"
    StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
    TargetLabel.Text = "🎯 TARGET: NONE"
    ToggleButton.Text = "START ORBIT"
    ToggleButton.BackgroundColor3 = Color3.fromRGB(0, 140, 0)
    ToggleStroke.Color = Color3.fromRGB(0, 255, 0)
end

-- === HEAD STOMP - SPAM LIÊN TỤC ===
local function startHeadStomp()
    if settings.headStomp then return end
    if settings.active then stopOrbit() end
    
    local target = findTarget()
    if not target then
        TargetLabel.Text = "🎯 TARGET: NO TARGET FOUND"
        return
    end
    
    settings.headStomp = true
    settings.target = target
    
    StatusLabel.Text = "🟣 HEAD STOMP ACTIVE"
    StatusLabel.TextColor3 = Color3.fromRGB(255, 150, 0)
    TargetLabel.Text = "🎯 TARGET: " .. target.Name
    HeadStompButton.Text = "👣 STOP STOMP"
    HeadStompButton.BackgroundColor3 = Color3.fromRGB(150, 50, 0)
    HeadStompStroke.Color = Color3.fromRGB(255, 0, 0)
    workspace.Gravity = 0
    
    if headStompConn then headStompConn:Disconnect() end
    
    -- SPAM MỖI FRAME
    headStompConn = RunService.RenderStepped:Connect(function()
        if not settings.headStomp then 
            headStompConn:Disconnect() 
            return 
        end
        
        if not settings.target or not settings.target.Character or not settings.target.Character:FindFirstChild("HumanoidRootPart") then
            settings.target = findTarget()
            if not settings.target then 
                stopHeadStomp() 
                return 
            end
            TargetLabel.Text = "🎯 TARGET: " .. settings.target.Name
        end
        
        local targetChar = settings.target.Character
        local myChar = player.Character
        if not myChar then return end
        local myRoot = myChar:FindFirstChild("HumanoidRootPart")
        if not myRoot then return end
        
        local headPos = getHeadPosition(targetChar)
        if headPos then
            -- TELEPORT LÊN ĐẦU MỖI FRAME + QUAY LIÊN TỤC
            local spin = tick() * 500
            myRoot.CFrame = CFrame.new(headPos + Vector3.new(0, 3, 0)) * CFrame.Angles(0, math.rad(spin), 0)
            myRoot.Velocity = Vector3.zero
            myRoot.RotVelocity = Vector3.zero
        end
        
        local hum = myChar:FindFirstChild("Humanoid")
        if hum then
            hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
            hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
            hum.PlatformStand = true
        end
    end)
end

local function stopHeadStomp()
    settings.headStomp = false
    if headStompConn then headStompConn:Disconnect() headStompConn = nil end
    workspace.Gravity = 196.2
    local char = player.Character
    if char then
        local hum = char:FindFirstChild("Humanoid")
        if hum then
            hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
            hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, true)
            hum.PlatformStand = false
        end
    end
    StatusLabel.Text = "🔴 INACTIVE"
    StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
    TargetLabel.Text = "🎯 TARGET: NONE"
    HeadStompButton.Text = "👣 HEAD STOMP"
    HeadStompButton.BackgroundColor3 = Color3.fromRGB(100, 50, 0)
    HeadStompStroke.Color = Color3.fromRGB(255, 150, 0)
end

