-- === CHỨC NĂNG TÌM MỤC TIÊU ===
local function findTarget()
    local nearest = nil
    local minDist = math.huge
    local myChar = player.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = myChar.HumanoidRootPart.Position
    
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local hum = p.Character:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 then
                local dist = (myPos - p.Character.HumanoidRootPart.Position).Magnitude
                if dist < minDist then
                    minDist = dist
                    nearest = p
                end
            end
        end
    end
    return nearest
end

-- === JITTER ORBIT ===
local function startOrbit()
    if settings.active then return end
    
    local target = findTarget()
    if not target then
        TargetLabel.Text = "🎯 TARGET: NO TARGET FOUND"
        return
    end
    
    settings.active = true
    settings.target = target
    settings.radius = math.clamp(tonumber(RadiusSlider.Text) or 10000, 1, 10000)
    settings.speed = math.clamp(tonumber(SpeedSlider.Text) or 10000, 1, 10000)
    
    StatusLabel.Text = "🟢 ORBIT ACTIVE"
    StatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    TargetLabel.Text = "🎯 TARGET: " .. target.Name
    ToggleButton.Text = "STOP ORBIT"
    ToggleButton.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
    ToggleStroke.Color = Color3.fromRGB(255, 0, 0)
    
    workspace.Gravity = 0
    
    local angleBase = 0
    local jitterPhase = 0
    
    if orbitConn then orbitConn:Disconnect() end
    
    orbitConn = RunService.Heartbeat:Connect(function(deltaTime)
        if not settings.active then
            orbitConn:Disconnect()
            return
        end
        
        if not settings.target or not settings.target.Character or not settings.target.Character:FindFirstChild("HumanoidRootPart") then
            settings.target = findTarget()
            if not settings.target then
                stopOrbit()
                return
            end
            TargetLabel.Text = "🎯 TARGET: " .. settings.target.Name
        end
        
        local targetRoot = settings.target.Character.HumanoidRootPart
        local myChar = player.Character
        if not myChar then return end
        local myRoot = myChar:FindFirstChild("HumanoidRootPart")
        if not myRoot then return end
        
        local now = tick()
        local interval = 1 / settings.speed
        if now - lastTeleport < interval then return end
        lastTeleport = now
        
        angleBase = (angleBase + 0.5) % (math.pi * 2)
        jitterPhase = jitterPhase + 0.7
        
        local r = settings.radius
        local targetPos = targetRoot.Position
        
        local baseX = math.sin(angleBase) * r
        local baseZ = math.cos(angleBase) * r
        
        local jitterX = math.sin(jitterPhase * 5) * (r * 0.5) + math.random(-settings.jitterAmount, settings.jitterAmount)
        local jitterY = math.cos(jitterPhase * 3) * (r * 0.6) + math.random(-settings.jitterAmount, settings.jitterAmount) + 30
        local jitterZ = math.sin(jitterPhase * 4) * (r * 0.4) + math.random(-settings.jitterAmount, settings.jitterAmount)
        
        local desiredPos = Vector3.new(
            targetPos.X + baseX + jitterX,
            targetPos.Y + jitterY,
            targetPos.Z + baseZ + jitterZ
        )
        
        myRoot.CFrame = CFrame.new(desiredPos)
        myRoot.CFrame = myRoot.CFrame * CFrame.Angles(
            math.rad(math.random(-60, 60)),
            math.rad(math.random(0, 360)),
            math.rad(math.random(-60, 60))
        )
        
        myRoot.Velocity = Vector3.zero
        myRoot.RotVelocity = Vector3.zero
        
        local hum = myChar:FindFirstChild("Humanoid")
        if hum then
            hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
            hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
        end
    end)
end

local function stopOrbit()
    settings.active = false
    if orbitConn then orbitConn:Disconnect() orbitConn = nil end
    
    workspace.Gravity = 196.2
    
    local char = player.Character
    if char then
        local hum = char:FindFirstChild("Humanoid")
        if hum then
            hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
            hum:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, true)
        end
    end
    
    StatusLabel.Text = "🔴 INACTIVE"
    StatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
    TargetLabel.Text = "🎯 TARGET: NONE"
    ToggleButton.Text = "START ORBIT"
    ToggleButton.BackgroundColor3 = Color3.fromRGB(0, 140, 0)
    ToggleStroke.Color = Color3.fromRGB(0, 255, 0)
end

